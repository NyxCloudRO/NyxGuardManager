FROM nyxmael/nyxguardmanager:4.0.8

COPY overlay/app/routes/nyxguard/attack-log.js /app/routes/nyxguard/attack-log.js
COPY overlay/app/routes/nyxguard/settings.js /app/routes/nyxguard/settings.js
COPY overlay/app/routes/nyxguard/rules.js /app/routes/nyxguard/rules.js
COPY overlay/app/routes/nyxguard/waf-rules.js /app/routes/nyxguard/waf-rules.js
COPY overlay/app/routes/web-threat.js /app/routes/web-threat.js
COPY overlay/app/internal/remote-version.js /app/internal/remote-version.js
COPY overlay/app/internal/user.js /app/internal/user.js
COPY overlay/app/lib/access.js /app/lib/access.js
COPY overlay/app/lib/access/*.json /app/lib/access/
COPY overlay/app/schema/components/permission-object.json /app/schema/components/permission-object.json
COPY overlay/app/schema/paths/users/userID/permissions/put.json /app/schema/paths/users/userID/permissions/put.json
COPY overlay/app/migrations/20260429120000_current_menu_permissions.js /app/migrations/20260429120000_current_menu_permissions.js
COPY overlay/app/package.json /app/package.json
COPY overlay/app/nginx/production.conf /etc/nginx/conf.d/production.conf
COPY overlay/app/patch-frontend-attacks.mjs /tmp/patch-frontend-attacks.mjs
COPY overlay/app/patch-frontend-legacy-pages.mjs /tmp/patch-frontend-legacy-pages.mjs

RUN find /app/frontend/assets -maxdepth 1 -type f -name '*408dev*' -exec sh -c 'for f; do cp "$f" "$(printf "%s" "$f" | sed "s/408dev/409dev/g")"; done' sh {} +
RUN node /tmp/patch-frontend-attacks.mjs && rm /tmp/patch-frontend-attacks.mjs
RUN node /tmp/patch-frontend-legacy-pages.mjs && rm /tmp/patch-frontend-legacy-pages.mjs
COPY overlay/app/frontend/assets/local-dev-fixes.js /app/frontend/assets/local-dev-fixes.js
COPY overlay/app/frontend/assets/local-dev-fixes-409dev.js /app/frontend/assets/local-dev-fixes-409dev.js
COPY overlay/app/frontend/index.html /app/frontend/index.html
